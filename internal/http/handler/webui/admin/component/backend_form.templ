			})
		</div>
	</div>
	<div class="space-y-2">
		@label.Label(label.Props{For: "backend_base_path"}) { Répertoire de base (dans le bucket) }
		@input.Input(input.Props{
			ID:    "backend_base_path",
			Name:  "backend_base_path",
			Type:  input.TypeText,
			Value: v.str("basePath"),
		})
	</div>
	<div class="flex items-center gap-2">
		<input
			type="checkbox"
			id="backend_secure"
			name="backend_secure"
			value="true"
			class="h-4 w-4 rounded border-input"
			checked?={ v.boolChecked("secure") }
		/>
		@label.Label(label.Props{For: "backend_secure"}) { Utiliser HTTPS }
	</div>
}

// --- Git ---

templ backendFormGit(v BackendFormVModel) {
	<div class="space-y-2">
		@label.Label(label.Props{For: "backend_url"}) { URL du dépôt }
		@input.Input(input.Props{
			ID:          "backend_url",
			Name:        "backend_url",
			Type:        input.TypeURL,
			Placeholder: "https://github.com/org/repo.git",
			Value:       v.str("url"),
			Attributes:  templ.Attributes{"required": true},
		})
	</div>
	<div class="grid grid-cols-2 gap-4">
		<div class="space-y-2">
			@label.Label(label.Props{For: "backend_branch"}) { Branche }
			@input.Input(input.Props{
				ID:          "backend_branch",
				Name:        "backend_branch",
				Type:        input.TypeText,
				Placeholder: "main (défaut HEAD)",
				Value:       v.str("branch"),
			})
		</div>
		<div class="space-y-2">
			@label.Label(label.Props{For: "backend_pull_interval"}) { Intervalle de pull }
			@input.Input(input.Props{
				ID:          "backend_pull_interval",
				Name:        "backend_pull_interval",
				Type:        input.TypeText,
				Placeholder: "30m",
				Value:       v.str("pullInterval"),
			})
		</div>
	</div>
}

// passwordPlaceholder returns a masked placeholder when an existing value is present.
func passwordPlaceholder(existing string) string {
	if existing != "" {
		return "••••••••"
	}
	return ""
}

// backendTypeLabel returns a human-readable label for a backend type.
func backendTypeLabel(backendType string) string {
	switch backendType {
	case "local":
		return "Local"
	case "sftp":
		return "SFTP"
	case "ftp":
		return "FTP"
	case "smb":
		return "SMB / CIFS"
	case "webdav":
		return "WebDAV"
	case "minio":
		return "MinIO / S3"
	case "git":
		return "Git"
	default:
		return fmt.Sprintf("Inconnu (%s)", backendType)
	}
}
