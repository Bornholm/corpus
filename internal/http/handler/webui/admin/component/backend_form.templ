			})
			if v.str("secretKey") != "" {
				<input type="hidden" name="backend_secret_key_existing" value={ v.str("secretKey") }/>
			}
		</div>
	</div>
	<div class="grid grid-cols-2 gap-4">
		<div class="space-y-2">
			@label.Label(label.Props{For: "backend_bucket"}) { Bucket }
			@input.Input(input.Props{
				ID:          "backend_bucket",
				Name:        "backend_bucket",
				Type:        input.TypeText,
				Placeholder: "default",
				Value:       v.str("bucket"),
			})
		</div>
		<div class="space-y-2">
			@label.Label(label.Props{For: "backend_region"}) { Région }
			@input.Input(input.Props{
				ID:          "backend_region",
				Name:        "backend_region",
				Type:        input.TypeText,
				Placeholder: "us-east-1",
